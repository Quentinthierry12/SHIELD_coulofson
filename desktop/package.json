{
  "name": "shield-desktop",
  "version": "1.0.0",
  "description": "S.H.I.E.L.D. Central Document System — desktop client",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "node fix-electron.js && electron .",
    "build": "electron-builder --win --publish never && node fix-electron.js",
    "fix": "node fix-electron.js",
    "postinstall": "node fix-electron.js"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "fr.quentinthierry.shield",
    "productName": "S.H.I.E.L.D.",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "menu.js",
      "shortcuts.js",
      "chrome/**",
      "assets/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "S.H.I.E.L.D."
    },
    "protocols": [
      {
        "name": "S.H.I.E.L.D.",
        "schemes": [
          "shield"
        ]
      }
    ]
  },
  "author": "Quentin Thierry"
}